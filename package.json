{
	"name": "dd-flag-migration",
	"version": "0.1.0",
	"description": "CLI tool to migrate feature flags to Datadog",
	"license": "Apache-2.0",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"dd-flag-migration": "dist/index.js"
	},
	"scripts": {
		"setup": "yarn install && yarn allow-scripts",
		"migrate": "tsx src/index.ts",
		"evaluate": "tsx src/evaluate.ts",
		"build": "tsc -p tsconfig.build.json",
		"start": "node dist/index.js",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"typecheck": "tsc",
		"test": "node --experimental-vm-modules node_modules/.bin/jest"
	},
	"dependencies": {
		"@eppo/node-server-sdk": "^4.0.0",
		"@inquirer/prompts": "^8.4.1",
		"axios": "^1.15.0",
		"chalk": "^5.3.0",
		"exceljs": "^4.4.0",
		"ora": "^9.3.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@lavamoat/allow-scripts": "^3.4.3",
		"@lavamoat/preinstall-always-fail": "^2.1.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.6.0",
		"axios-mock-adapter": "^2.1.0",
		"jest": "^30.3.0",
		"ts-jest": "^29.4.9",
		"tsx": "^4.0.0",
		"typescript": "^6.0.2"
	},
	"lavamoat": {
		"allowScripts": {
			"$root$": false,
			"@lavamoat/preinstall-always-fail": false,
			"tsx>esbuild": true,
			"jest>@jest/core>jest-resolve>unrs-resolver": true
		}
	},
	"engines": {
		"yarn": "1.x"
	},
	"packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
